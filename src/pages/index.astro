      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .hero__inner {
    display: grid;
    grid-template-columns: minmax(12rem, 2fr) minmax(0, 3fr);
    align-items: center;
    gap: clamp(2rem, 5vw, 4.5rem);
  }

  .hero__image {
    width: min(100%, 22rem);
    justify-self: center;
    border-radius: 2px;
  }

  .hero__copy p {
    max-width: 31rem;
    font-size: clamp(1.05rem, 1.5vw, 1.2rem);
    color: var(--color-muted);
  }

  .prose-block p {
    color: var(--color-text);
  }

  .section-heading--center {
    text-align: center;
  }

  .follow-section {
    text-align: center;
  }

  .follow-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .follow-list a {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
  }

  .follow-list a:hover span,
  .follow-list a:focus-visible span {
    text-decoration: underline;
  }

  .follow-list svg {
    width: 1rem;
    height: 1rem;
    fill: currentColor;
  }

  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .hero__copy {
      max-width: var(--content-width);
    }
  }
</style>

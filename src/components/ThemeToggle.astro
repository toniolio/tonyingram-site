<div class="theme-picker" data-theme-picker data-open="false">
  <button
    class="theme-toggle"
    type="button"
    data-theme-toggle
    data-theme-trigger
    data-theme-preference="system"
    aria-haspopup="true"
    aria-expanded="false"
    aria-label="Theme: System"
    title="Theme: System"
  >
    <span class="theme-toggle__icon theme-toggle__icon--system" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3.5" y="4.5" width="17" height="12" rx="1.5" stroke-width="1.6"></rect>
        <path d="M8 19.5h8M12 16.5v3" stroke-width="1.6"></path>
      </svg>
    </span>
    <span class="theme-toggle__icon theme-toggle__icon--sun" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4" stroke-width="1.6"></circle>
        <path d="M12 2.5v2.5M12 19v2.5M21.5 12H19M5 12H2.5M18.7 5.3l-1.8 1.8M7.1 16.9l-1.8 1.8M18.7 18.7l-1.8-1.8M7.1 7.1 5.3 5.3" stroke-width="1.6"></path>
      </svg>
    </span>
    <span class="theme-toggle__icon theme-toggle__icon--moon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 14.2A8 8 0 1 1 9.8 4 6.5 6.5 0 0 0 20 14.2Z" stroke-width="1.6"></path>
      </svg>
    </span>
  </button>
  <div class="theme-picker__panel" data-theme-panel role="group" aria-label="Theme" hidden>
    <button class="theme-picker__option" type="button" data-theme-option="system" aria-pressed="true">
      System
    </button>
    <button class="theme-picker__option" type="button" data-theme-option="light" aria-pressed="false">
      Light
    </button>
    <button class="theme-picker__option" type="button" data-theme-option="dark" aria-pressed="false">
      Dark
    </button>
  </div>
</div>

<script is:inline>
  (() => {
    if (window.__themeToggleInitialized) {
      return;
    }

    window.__themeToggleInitialized = true;

    const storageKey = "theme-preference";
    const initializeThemeToggle = () => {
      const root = document.documentElement;
      const pickers = Array.from(document.querySelectorAll("[data-theme-picker]")).filter(
        (picker) => picker instanceof HTMLDivElement,
      );

      if (pickers.length === 0) {
        return;
      }

      const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");
      const getSystemTheme = () => (mediaQuery.matches ? "dark" : "light");
      const getStoredPreference = () => {
        const storedTheme = localStorage.getItem(storageKey);
        return storedTheme === "light" || storedTheme === "dark" ? storedTheme : null;
      };
      const resolveTheme = (preference) => preference ?? getSystemTheme();
      const setPickerOpenState = (picker, isOpen) => {
        const trigger = picker.querySelector("[data-theme-trigger]");
        const panel = picker.querySelector("[data-theme-panel]");

        if (!(trigger instanceof HTMLButtonElement) || !(panel instanceof HTMLDivElement)) {
          return;
        }

        picker.dataset.open = isOpen ? "true" : "false";
        trigger.setAttribute("aria-expanded", isOpen ? "true" : "false");
        panel.hidden = !isOpen;
      };
      const closeAllPickers = () => {
        pickers.forEach((picker) => setPickerOpenState(picker, false));
      };
      const syncTheme = () => {
        const preference = getStoredPreference();
        const resolvedTheme = resolveTheme(preference);

        root.dataset.theme = resolvedTheme;
        root.style.colorScheme = resolvedTheme;

        pickers.forEach((picker) => {
          const trigger = picker.querySelector("[data-theme-trigger]");
          const options = Array.from(picker.querySelectorAll("[data-theme-option]")).filter(
            (button) => button instanceof HTMLButtonElement,
          );
          const activePreference = preference ?? "system";

          if (trigger instanceof HTMLButtonElement) {
            const preferenceLabel =
              activePreference.charAt(0).toUpperCase() + activePreference.slice(1);

            trigger.dataset.themePreference = activePreference;
            trigger.setAttribute("aria-label", `Theme: ${preferenceLabel}`);
            trigger.setAttribute("title", `Theme: ${preferenceLabel}`);
          }

          options.forEach((option) => {
            const isPressed = option.dataset.themeOption === activePreference;
            option.setAttribute("aria-pressed", isPressed ? "true" : "false");
          });
        });
      };
      const setThemePreference = (preference) => {
        if (preference === "light" || preference === "dark") {
          localStorage.setItem(storageKey, preference);
        } else {
          localStorage.removeItem(storageKey);
        }

        syncTheme();
        closeAllPickers();
      };
      const togglePicker = (picker) => {
        const panel = picker.querySelector("[data-theme-panel]");
        const shouldOpen = panel instanceof HTMLDivElement ? panel.hidden : true;

        closeAllPickers();
        setPickerOpenState(picker, shouldOpen);
      };

      syncTheme();

      pickers.forEach((picker) => {
        const trigger = picker.querySelector("[data-theme-trigger]");
        const options = Array.from(picker.querySelectorAll("[data-theme-option]")).filter(
          (button) => button instanceof HTMLButtonElement,
        );

        if (trigger instanceof HTMLButtonElement) {
          trigger.addEventListener("click", (event) => {
            event.stopPropagation();
            togglePicker(picker);
          });
        }

        options.forEach((button) => {
          button.addEventListener("click", () => {
            const preference = button.dataset.themeOption;
            setThemePreference(
              preference === "light" || preference === "dark" ? preference : null,
            );
          });
        });
      });

      document.addEventListener("click", (event) => {
        if (!(event.target instanceof Node)) {
          return;
        }

        const clickedInsidePicker = pickers.some((picker) => picker.contains(event.target));

        if (!clickedInsidePicker) {
          closeAllPickers();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeAllPickers();
        }
      });

      const handleSystemThemeChange = () => {
        if (getStoredPreference() !== null) {
          return;
        }

        syncTheme();
      };

      mediaQuery.addEventListener("change", handleSystemThemeChange);
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initializeThemeToggle, { once: true });
      return;
    }

    initializeThemeToggle();
  })();
</script>

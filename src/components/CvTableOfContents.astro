---
interface Props {
  targetSelector?: string;
  topHref?: string;
}

const {
  targetSelector = ".cv-document .cv",
  topHref = "#cv-top",
} = Astro.props;
---

<div
  class="cv-page__toc cv-toc"
  data-cv-toc-root
  data-target-selector={targetSelector}
  hidden
>
  <details class="cv-toc__mobile" data-cv-toc-mobile>
    <summary class="cv-toc__mobile-toggle">Contents</summary>
    <nav class="cv-toc__mobile-panel" aria-label="Table of contents">
      <ul class="cv-toc__list" data-cv-toc-mobile-list></ul>
      <a class="cv-toc__top-link" href={topHref}>Back to top</a>
    </nav>
  </details>

  <aside class="cv-toc__desktop" aria-labelledby="cv-toc-title" data-cv-toc-desktop>
    <nav class="cv-toc__desktop-nav" aria-labelledby="cv-toc-title">
      <h2 id="cv-toc-title" class="cv-toc__title">On this page</h2>
      <ul class="cv-toc__list" data-cv-toc-desktop-list></ul>
      <a class="cv-toc__top-link" href={topHref}>Back to top</a>
    </nav>
  </aside>
</div>

<script is:inline>
  (() => {
    const slugify = (value) =>
      value
        .toLowerCase()
        .trim()
        .replace(/&/g, " and ")
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-+|-+$/g, "");

    const buildEntries = (container) => {
      const headings = Array.from(container.querySelectorAll("h2, h3"));
      const usedIds = new Set();
      const entries = [];
      let currentSectionId = null;

      headings.forEach((heading, index) => {
        const text = heading.textContent?.replace(/\s+/g, " ").trim() ?? "";

        if (!text) {
          return;
        }

        if (index === 0 && !heading.id) {
          return;
        }

        const baseId =
          heading.id.trim() || slugify(text) || `section-${entries.length + 1}`;

        let id = baseId;
        let suffix = 2;

        while (
          usedIds.has(id) ||
          (document.getElementById(id) &&
            document.getElementById(id) !== heading)
        ) {
          id = `${baseId}-${suffix}`;
          suffix += 1;
        }

        if (heading.id !== id) {
          heading.id = id;
        }

        const level = Number(heading.tagName.slice(1));

        if (level === 2) {
          currentSectionId = id;
        }

        usedIds.add(id);
        entries.push({
          id,
          text,
          level,
          parentId: level === 3 ? currentSectionId : null,
        });
      });

      return entries;
    };

    const createItem = (entry) => {
      const item = document.createElement("li");
      item.className = `cv-toc__item cv-toc__item--level-${entry.level}`;
      item.dataset.cvTocEntryId = entry.id;

      if (entry.parentId) {
        item.dataset.cvTocParentId = entry.parentId;
      }

      const link = document.createElement("a");
      link.href = `#${entry.id}`;
      link.textContent = entry.text;
      link.dataset.cvTocLinkId = entry.id;

      item.append(link);
      return item;
    };

    const fillList = (list, entries) => {
      list.replaceChildren();

      let currentSectionItem = null;
      let currentSublist = null;

      entries.forEach((entry) => {
        if (entry.level === 2 || !currentSectionItem) {
          currentSectionItem = createItem(entry);
          currentSublist = null;
          list.append(currentSectionItem);
          return;
        }

        if (!currentSublist) {
          currentSublist = document.createElement("ul");
          currentSublist.className = "cv-toc__sublist";
          currentSectionItem.append(currentSublist);
        }

        currentSublist.append(createItem(entry));
      });
    };

    const collectEntryNodes = (root) => {
      const entryNodesById = new Map();

      root.querySelectorAll("[data-cv-toc-entry-id]").forEach((item) => {
        if (!(item instanceof HTMLLIElement)) {
          return;
        }

        const id = item.dataset.cvTocEntryId;

        if (!id) {
          return;
        }

        const link = item.firstElementChild;
        const entryNodes = entryNodesById.get(id) ?? { items: [], links: [] };

        entryNodes.items.push(item);

        if (link instanceof HTMLAnchorElement) {
          entryNodes.links.push(link);
        }

        entryNodesById.set(id, entryNodes);
      });

      return entryNodesById;
    };

    const applyActiveState = (entriesById, entryNodesById, activeId) => {
      const activeEntry = activeId ? entriesById.get(activeId) ?? null : null;
      const currentSectionId = activeEntry
        ? activeEntry.level === 3
          ? activeEntry.parentId
          : activeEntry.id
        : null;
      const currentSubsectionId = activeEntry?.level === 3 ? activeEntry.id : null;

      entryNodesById.forEach((entryNodes, id) => {
        const isActive = id === activeId;
        const isCurrentSection = id === currentSectionId;
        const isCurrentSubsection = id === currentSubsectionId;

        entryNodes.items.forEach((item) => {
          item.classList.toggle("cv-toc__item--active", isActive);
          item.classList.toggle("cv-toc__item--current-section", isCurrentSection);
          item.classList.toggle(
            "cv-toc__item--current-subsection",
            isCurrentSubsection,
          );
        });

        entryNodes.links.forEach((link) => {
          if (isActive) {
            link.setAttribute("aria-current", "location");
          } else {
            link.removeAttribute("aria-current");
          }
        });
      });
    };

    const setDesktopOverflow = (root) => {
      const desktopNav = root.querySelector(".cv-toc__desktop-nav");

      if (!(desktopNav instanceof HTMLElement)) {
        return;
      }

      root.classList.remove("cv-toc--desktop-scrollable");
      desktopNav.style.removeProperty("--cv-toc-max-height");

      if (!window.matchMedia("(min-width: 900px)").matches) {
        return;
      }

      const topOffset = Number.parseFloat(getComputedStyle(root).top) || 0;
      const maxHeight = Math.floor(window.innerHeight - topOffset - 24);

      if (desktopNav.scrollHeight > maxHeight) {
        root.classList.add("cv-toc--desktop-scrollable");
        desktopNav.style.setProperty("--cv-toc-max-height", `${maxHeight}px`);
      }
    };

    const initRoot = (root) => {
      const targetSelector = root.dataset.targetSelector;

      if (!targetSelector) {
        return;
      }

      const target = document.querySelector(targetSelector);

      if (!target) {
        return;
      }

      const entries = buildEntries(target);

      if (!entries.length) {
        return;
      }

      const desktopList = root.querySelector("[data-cv-toc-desktop-list]");
      const mobileList = root.querySelector("[data-cv-toc-mobile-list]");

      if (!(desktopList instanceof HTMLUListElement)) {
        return;
      }

      if (!(mobileList instanceof HTMLUListElement)) {
        return;
      }

      fillList(desktopList, entries);
      fillList(mobileList, entries);
      root.hidden = false;

      const entriesById = new Map(entries.map((entry) => [entry.id, entry]));
      const entryNodesById = collectEntryNodes(root);
      const headings = entries
        .map((entry) => document.getElementById(entry.id))
        .filter((heading) => heading instanceof HTMLElement);

      let activeId = null;
      let activeSyncFrame = 0;

      const getActivationOffset = () =>
        Math.min(Math.max(window.innerHeight * 0.22, 120), 200);

      const getActiveHeadingId = () => {
        if (headings.length === 0) {
          return null;
        }

        if (
          window.scrollY + window.innerHeight >=
          document.documentElement.scrollHeight - 8
        ) {
          return headings.at(-1)?.id ?? null;
        }

        const activationOffset = getActivationOffset();
        let currentHeading = headings[0];

        headings.forEach((heading) => {
          if (heading.getBoundingClientRect().top <= activationOffset) {
            currentHeading = heading;
          }
        });

        return currentHeading.id || null;
      };

      const syncActiveState = () => {
        activeSyncFrame = 0;

        const nextActiveId = getActiveHeadingId();

        if (nextActiveId === activeId) {
          return;
        }

        activeId = nextActiveId;
        applyActiveState(entriesById, entryNodesById, activeId);
      };

      const requestActiveSync = () => {
        if (activeSyncFrame !== 0) {
          return;
        }

        activeSyncFrame = window.requestAnimationFrame(syncActiveState);
      };

      const mobileDetails = root.querySelector("[data-cv-toc-mobile]");

      if (mobileDetails instanceof HTMLDetailsElement) {
        mobileDetails.querySelectorAll('a[href^="#"]').forEach((link) => {
          link.addEventListener("click", () => {
            mobileDetails.open = false;
            requestActiveSync();
          });
        });

        document.addEventListener("click", (event) => {
          const target = event.target;

          if (target instanceof Node && !mobileDetails.contains(target)) {
            mobileDetails.open = false;
          }
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") {
            mobileDetails.open = false;
          }
        });
      }

      if ("IntersectionObserver" in window) {
        const headingObserver = new IntersectionObserver(requestActiveSync, {
          rootMargin: "-20% 0px -65% 0px",
          threshold: [0, 1],
        });

        headings.forEach((heading) => {
          headingObserver.observe(heading);
        });
      }

      const syncDesktopOverflow = () => {
        window.requestAnimationFrame(() => {
          setDesktopOverflow(root);
        });
      };

      requestActiveSync();
      syncDesktopOverflow();
      window.addEventListener("scroll", requestActiveSync, { passive: true });
      window.addEventListener("hashchange", requestActiveSync);
      window.addEventListener("resize", syncDesktopOverflow);
      window.addEventListener("resize", requestActiveSync);
    };

    const init = () => {
      document.querySelectorAll("[data-cv-toc-root]").forEach((root) => {
        if (root instanceof HTMLElement) {
          initRoot(root);
        }
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init, { once: true });
    } else {
      init();
    }
  })();
</script>

<style>
  .cv-toc {
    position: sticky;
    top: 0.85rem;
    z-index: 4;
    width: fit-content;
    margin: 0 0 var(--space-4) auto;
  }

  .cv-toc__mobile {
    position: relative;
  }

  .cv-toc__mobile-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 0.95rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-surface);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.1);
    font-weight: 600;
    cursor: pointer;
    list-style: none;
  }

  .cv-toc__mobile-toggle::-webkit-details-marker {
    display: none;
  }

  .cv-toc__mobile-toggle:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .cv-toc__mobile-toggle::after {
    content: "";
    width: 0.55rem;
    height: 0.55rem;
    border-right: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: translateY(-0.1rem) rotate(45deg);
    transition: transform 140ms ease;
  }

  .cv-toc__mobile[open] .cv-toc__mobile-toggle::after {
    transform: translateY(0.1rem) rotate(-135deg);
  }

  .cv-toc__mobile-panel {
    position: absolute;
    top: calc(100% + 0.6rem);
    right: 0;
    width: min(18rem, calc(100vw - 2rem));
    max-height: calc(100vh - 5.75rem);
    padding: 1rem;
    overflow: auto;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background: var(--color-surface);
    box-shadow: 0 20px 38px rgba(0, 0, 0, 0.14);
    scrollbar-width: thin;
  }

  .cv-toc__desktop {
    display: none;
    position: relative;
  }

  .cv-toc__title {
    margin: 0 0 0.9rem;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
  }

  .cv-toc__list {
    margin: 0 0 var(--space-3);
    padding: 0;
    list-style: none;
  }

  :global(.cv-toc__sublist) {
    margin: 0.5rem 0 0;
    padding: 0 0 0 0.95rem;
    border-left: 1px solid var(--color-border);
    list-style: none;
  }

  :global(.cv-toc__item--level-2 + .cv-toc__item--level-2) {
    margin-top: 0.95rem;
  }

  :global(.cv-toc__item--level-3) {
    margin-top: 0.42rem;
    padding-left: 0.35rem;
  }

  :global(.cv-toc__item a) {
    display: inline-block;
    padding: 0.12rem 0.38rem;
    margin-left: -0.38rem;
    border-radius: 0.45rem;
    text-decoration: none;
    transition:
      color 140ms ease,
      background-color 140ms ease,
      border-color 140ms ease,
      box-shadow 140ms ease;
  }

  :global(.cv-toc__item--level-2 a) {
    color: var(--color-heading);
    font-weight: 600;
  }

  :global(.cv-toc__item--level-3 a) {
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  :global(.cv-toc__item--current-section > a) {
    color: var(--color-heading);
    background: var(--color-surface-strong);
  }

  :global(.cv-toc__item--level-2.cv-toc__item--current-section > a) {
    font-weight: 700;
  }

  :global(.cv-toc__item--level-2.cv-toc__item--active > a) {
    box-shadow: 0 0 0 1px var(--color-border);
  }

  :global(.cv-toc__item--current-section > .cv-toc__sublist) {
    border-left-color: var(--color-heading);
  }

  :global(.cv-toc__item--level-3.cv-toc__item--current-subsection > a) {
    color: var(--color-heading);
    background: var(--color-surface-strong);
    font-weight: 700;
    box-shadow: 0 0 0 1px var(--color-border);
  }

  :global(.cv-toc__item a:hover),
  :global(.cv-toc__item a:focus-visible),
  .cv-toc__top-link:hover,
  .cv-toc__top-link:focus-visible {
    text-decoration: underline;
    text-underline-offset: 0.22em;
  }

  .cv-toc__top-link {
    display: inline-block;
    font-size: 0.95rem;
    color: var(--color-muted);
  }

  @media (min-width: 900px) {
    .cv-toc {
      position: sticky;
      top: var(--space-5);
      width: auto;
      margin: 0;
    }

    .cv-toc__mobile {
      display: none;
    }

    .cv-toc__desktop {
      display: block;
    }

    .cv-toc__desktop-nav {
      padding-left: 0.45rem;
      padding-right: 1.25rem;
      border-right: 1px solid var(--color-border);
    }

    :global(.cv-toc__item a) {
      margin-left: 0;
    }

    .cv-toc--desktop-scrollable .cv-toc__desktop-nav {
      max-height: var(--cv-toc-max-height);
      padding-bottom: 1.25rem;
      overflow: auto;
      scrollbar-gutter: stable;
      scrollbar-width: thin;
    }

    .cv-toc--desktop-scrollable .cv-toc__desktop::after {
      content: "";
      position: absolute;
      left: 0;
      right: 1rem;
      bottom: 0;
      height: 1.5rem;
      background: linear-gradient(to bottom, transparent, var(--color-background));
      pointer-events: none;
    }
  }
</style>

---
import CvDocument from "../components/CvDocument.astro";
import CvTableOfContents from "../components/CvTableOfContents.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Curriculum Vitae - Tony Ingram, PhD"
  description="Long-form curriculum vitae for Tony Ingram, PhD."
  canonicalPath="/cv/"
>
  <section class="section">
    <div class="site-shell narrow-shell cv-page" id="cv-top">
      <div class="cv-page__intro">
        <h1>Curriculum Vitae</h1>
        <p>This is a long form, somewhat &ldquo;academic&rdquo; style curriculum vitae.</p>
        <p>
          For something more concise, see my
          <a href="https://www.linkedin.com/in/tgjingram/">LinkedIn profile</a>.
        </p>
      </div>

      <CvTableOfContents />

      <div class="cv-page__content">
        <CvDocument />
        <p class="cv-page__back-to-top"><a href="#cv-top">Back to top</a></p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .cv-page {
    color: var(--color-text);
  }

  .cv-page__intro {
    max-width: var(--content-width);
    margin-bottom: var(--space-5);
  }

  .cv-page__intro > p {
    color: var(--color-muted);
  }

  .cv-page__content {
    min-width: 0;
    max-width: var(--content-width);
  }

  .cv-page__back-to-top {
    margin-top: var(--space-5);
  }

  .cv-page__back-to-top a {
    color: var(--color-muted);
  }

  :global(.cv-document .cv h2) {
    margin-top: 2.25rem;
    margin-bottom: 0.9rem;
    font-size: 1.85rem;
  }

  :global(.cv-document .cv h3) {
    margin-top: 1.8rem;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
  }

  :global(.cv-document .cv p),
  :global(.cv-document .cv ul),
  :global(.cv-document .cv ol) {
    margin-bottom: 1rem;
  }

  :global(.cv-document .cv ul),
  :global(.cv-document .cv ol) {
    padding-left: 1.35rem;
  }

  :global(.cv-document .cv li + li) {
    margin-top: 0.45rem;
  }

  :global(.cv-document .cv .cv-entry) {
    margin-top: 1.4rem;
  }

  :global(.cv-document .cv .cv-role) {
    margin-bottom: 0.6rem;
  }

  :global(.cv-document .cv a) {
    overflow-wrap: anywhere;
  }

  :global(.cv-document .cv h2[id]),
  :global(.cv-document .cv h3[id]) {
    scroll-margin-top: var(--space-5);
  }

  @media (min-width: 980px) {
    .cv-page {
      width: min(calc(100% - 3rem), var(--shell-width));
      display: grid;
      grid-template-columns: minmax(14rem, 17rem) minmax(0, var(--content-width));
      column-gap: clamp(2rem, 5vw, 4rem);
      align-items: start;
    }

    .cv-page__intro {
      grid-column: 2;
      margin-bottom: var(--space-5);
    }

    .cv-page__content {
      grid-column: 2;
    }

    :global(.cv-page__toc) {
      grid-column: 1;
      grid-row: 2;
      align-self: start;
    }
  }

  @media (max-width: 720px) {
    :global(.cv-document .cv h2) {
      font-size: 1.55rem;
    }

    :global(.cv-document .cv h3) {
      font-size: 1.15rem;
    }
  }
</style>

---
const currentYear = new Date().getFullYear();
const startYear = 2025;
const copyrightYears = currentYear > startYear ? `${startYear} - ${currentYear}` : `${currentYear}`;
---

<footer class="site-footer">
  <div class="site-shell">
    <p>© Tony Ingram. {copyrightYears}. All Rights Reserved.</p>
  </div>
</footer>
